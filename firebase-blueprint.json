{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A shop product item.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "stock": { "type": "number" },
        "articleNumber": { "type": "string" },
        "metaTitle": { "type": "string" },
        "metaDescription": { "type": "string" },
        "metaAdsText": { "type": "string" },
        "plannerType": { "type": "string" }
      },
      "required": ["id", "name", "price", "category"]
    },
    "User": {
      "title": "User",
      "description": "Store non-sensitive public user profile info like display name.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      },
      "required": ["id", "username", "email"]
    },
    "Plan": {
      "title": "Plan",
      "description": "Irrigation plans created by users.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "plannerData": { "type": "object" },
        "canvasState": { "type": "object" },
        "lastEdited": { "type": "string" }
      },
      "required": ["id", "userId", "name"]
    },
    "Order": {
      "title": "Order",
      "description": "Shop purchase order details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "date": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "items": { "type": "array" }
      },
      "required": ["id", "customerName", "total", "status", "items"]
    },
    "Cart": {
      "title": "Cart",
      "description": "User shopping cart state for session sync.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "items"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Catalog of available garden and irrigation products."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile records containing basic metadata."
    },
    "/plans/{planId}": {
      "schema": "Plan",
      "description": "Saved customized watering plans."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer purchase orders for fulfillment tracking."
    },
    "/carts/{userId}": {
      "schema": "Cart",
      "description": "Persisted shopping cart for logged-in users."
    }
  }
}
